# Environment Configuration

# Paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
GRAPH_DATA_DIR=./data/graphs
EXPERIMENTS_DIR=./experiments
OUTPUTS_DIR=./outputs

# Model Configuration
MODEL_NAME=gat_fakenews
HIDDEN_CHANNELS=128
NUM_ATTENTION_HEADS=8
NUM_LAYERS=3
DROPOUT=0.3

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=0.001
NUM_EPOCHS=100
EARLY_STOPPING_PATIENCE=10
GRADIENT_CLIP=1.0

# Feature Configuration
TEXT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_TEXT_LENGTH=512
USE_BERT_EMBEDDINGS=true

# Experiment Tracking
USE_WANDB=false
WANDB_PROJECT=fake-news-gat
WANDB_ENTITY=your-entity

# Device
DEVICE=cuda  # Options: cuda, mps, cpu

# Random Seeds
RANDOM_SEED=42

# Logging
LOG_LEVEL=INFO
